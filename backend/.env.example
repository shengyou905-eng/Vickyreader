PORT=3000
NODE_ENV=development

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=30d

DATABASE_URL=postgres://postgres:postgres@localhost:5432/reader
CORS_ORIGIN=http://localhost:3000

DEEPSEEK_API_KEY=
